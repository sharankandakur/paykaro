generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url=env("DATABASE_URL")
}

model Company {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  phone       String?
  isActive    Boolean  @default(true)
  trialEndsAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users         User[]
  employees     Employee[]
  attendance    Attendance[]
  leaveRequests LeaveRequest[]
  payrollRuns   PayrollRun[]
  usageEvents   UsageEvent[]
  invoices      Invoice[]

  @@map("companies")
}

model User {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  email       String   @unique
  password    String
  role        UserRole @default(HR_ADMIN)
  isActive    Boolean  @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime @default(now())

  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  HR_ADMIN
  MANAGER
  EMPLOYEE
}

model Employee {
  id             String         @id @default(uuid())
  companyId      String
  company        Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employeeCode   String
  firstName      String
  lastName       String
  email          String?
  phone          String
  whatsappNumber String?
  department     String
  designation    String
  dateOfJoining  DateTime
  dateOfLeaving  DateTime?
  employmentType EmploymentType @default(FULL_TIME)
  isActive       Boolean        @default(true)
  basicSalary    Float
  hra            Float?
  specialAllow   Float?
  pfApplicable   Boolean        @default(true)
  esiApplicable  Boolean        @default(true)
  ptApplicable   Boolean        @default(true)
  bankName       String?
  accountNumber  String?
  ifscCode       String?
  panNumber      String?
  pfNumber       String?
  esiNumber      String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  attendance    Attendance[]
  leaveRequests LeaveRequest[]
  payslips      Payslip[]

  @@unique([companyId, employeeCode])
  @@map("employees")
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
}

model Attendance {
  id            String           @id @default(uuid())
  companyId     String
  company       Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employeeId    String
  employee      Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date          DateTime         @db.Date
  status        AttendanceStatus @default(PRESENT)
  checkIn       String?
  checkOut      String?
  overtimeHours Float?           @default(0)
  note          String?
  createdAt     DateTime         @default(now())

  @@unique([employeeId, date])
  @@map("attendance")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  HOLIDAY
  WEEKLY_OFF
  ON_LEAVE
}

model LeaveRequest {
  id          String      @id @default(uuid())
  companyId   String
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employeeId  String
  employee    Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType   LeaveType
  startDate   DateTime    @db.Date
  endDate     DateTime    @db.Date
  totalDays   Float
  reason      String?
  status      LeaveStatus @default(PENDING)
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("leave_requests")
}

enum LeaveType {
  CASUAL
  SICK
  EARNED
  MATERNITY
  PATERNITY
  UNPAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model PayrollRun {
  id              String        @id @default(uuid())
  companyId       String
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  month           Int
  year            Int
  status          PayrollStatus @default(DRAFT)
  totalGross      Float
  totalDeductions Float
  totalNet        Float
  employerPF      Float
  employerESI     Float
  processedAt     DateTime?
  processedBy     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  payslips Payslip[]

  @@unique([companyId, month, year])
  @@map("payroll_runs")
}

enum PayrollStatus {
  DRAFT
  PROCESSED
  PAID
  LOCKED
}

model Payslip {
  id               String     @id @default(uuid())
  payrollRunId     String
  payrollRun       PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employeeId       String
  employee         Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  basicSalary      Float
  hra              Float
  specialAllow     Float
  overtimePay      Float      @default(0)
  grossSalary      Float
  pfEmployee       Float
  esiEmployee      Float
  professionalTax  Float      @default(0)
  advanceDeduction Float      @default(0)
  otherDeductions  Float      @default(0)
  totalDeductions  Float
  netSalary        Float
  daysWorked       Float
  daysInMonth      Int
  sentViaWhatsApp  Boolean    @default(false)
  sentViaEmail     Boolean    @default(false)
  sentAt           DateTime?
  createdAt        DateTime   @default(now())

  @@unique([payrollRunId, employeeId])
  @@map("payslips")
}

model UsageEvent {
  id          String    @id @default(uuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  eventType   UsageType
  quantity    Int       @default(1)
  unitPrice   Float
  totalAmount Float
  metadata    Json?
  billedIn    String?
  createdAt   DateTime  @default(now())

  @@map("usage_events")
}

enum UsageType {
  EMPLOYEE_MONTHLY
  PAYROLL_RUN
  PAYSLIP_WHATSAPP
  PAYSLIP_EMAIL
  COMPLIANCE_REPORT
  BANK_FILE_EXPORT
}

model Invoice {
  id                String        @id @default(uuid())
  companyId         String
  company           Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoiceNumber     String        @unique
  month             Int
  year              Int
  subtotal          Float
  gst               Float
  total             Float
  status            InvoiceStatus @default(PENDING)
  razorpayOrderId   String?
  razorpayPaymentId String?
  paidAt            DateTime?
  dueDate           DateTime
  lineItems         Json
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@map("invoices")
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  WAIVED
}